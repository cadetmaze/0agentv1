# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...    # from @BotFather
ANTHROPIC_API_KEY=sk-ant-...              # or OPENAI_API_KEY=sk-...

# ── LLM (optional, defaults shown) ───────────────────────────────────────────
LLM_PROVIDER=anthropic                    # anthropic | openai | xai | gemini
LLM_MODEL=claude-sonnet-4-6

# ── Capacity (optional, defaults shown) ──────────────────────────────────────
MAX_CONTAINERS=50                         # max simultaneous users
IDLE_TIMEOUT_MIN=30                       # destroy container after N idle minutes
CONTAINER_MEMORY_MB=512                   # RAM per user container
